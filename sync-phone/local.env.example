# sync-phone — local.env
#
# Copy this file to `local.env` and edit. `local.env` is .gitignored.
# `setup.sh` reads it to install sync-phone into Claude Code and Codex CLI.
#
# Everything below has safe defaults. Override only what differs on your Mac.

# --- Paths ---

# Where the iPhone Shortcut appends raw dictation. Must be in iCloud Drive so
# both your phone and your Mac can reach it.
CAPTURE_DIR="$HOME/Library/Mobile Documents/com~apple~CloudDocs/_obsidian-capture"

# Parent directory containing your Obsidian vaults. The skill auto-discovers
# every subdirectory that contains a CLAUDE.md (or AGENTS.md).
VAULTS_DIR="$HOME/Documents/Obsidian"

# --- Claude side ---

# Model the Claude install will use. Most users leave this alone.
MODEL="claude-sonnet-4-6"

# --- Codex side (only used if you install the optional cron) ---

# Model + reasoning Codex should use when the optional automation runs.
CODEX_MODEL="gpt-5.5"
CODEX_REASONING="xhigh"

# Working directory Codex runs in. Defaults to the vaults parent so vault
# writes are inside Codex's cwd. Override if your Codex sandbox is narrower.
CODEX_CWD="$VAULTS_DIR"

# IANA timezone + local hour for the optional cron (only used if you flip the
# rendered automation.toml's status to "ACTIVE").
TIMEZONE="America/New_York"
CRON_HOUR="22"
