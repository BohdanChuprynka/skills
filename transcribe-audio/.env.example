# transcribe-audio environment configuration.
# Copy this file to .env and fill in your values. .env is gitignored.

# REQUIRED: OpenAI API key — used for Whisper transcription + LLM summary.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-replace-me

# OPTIONAL: path to your Obsidian vault.
# If set, takes precedence over `vault_path` in ~/.config/transcribe-audio/config.yaml.
# Example: /Users/yourname/Documents/Obsidian/personal
# OBSIDIAN_VAULT_PATH=
