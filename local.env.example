# local.env — your personalized config. THE ONLY FILE YOU EDIT before running setup.sh.
#
# Copy this template:   cp local.env.example local.env
# Edit the values:      $EDITOR local.env
# Wire everything:      bash setup.sh
#
# Real local.env is gitignored — never committed. setup.sh reads it once and generates
# settings.conf, mcp-config.json, automation.toml from it. Re-run setup.sh after edits.

# =============================================================================
# REQUIRED — basic identity
# =============================================================================

# Where your Obsidian "Calendar Context" markdown lives. The planner READS this each run.
CALENDAR_CONTEXT_PATH="/Users/<you>/Documents/Obsidian/me/wiki/Calendar Context.md"

# Obsidian vault root. The filesystem MCP is scoped to this dir.
OBSIDIAN_VAULT_ROOT="/Users/<you>/Documents/Obsidian"

# Title of the Notion page that lists tomorrow's tasks.
NOTION_PAGE_TITLE="12-Week Planner"

# =============================================================================
# REQUIRED — Notion integration token
# =============================================================================
# Get one at https://www.notion.so/profile/integrations → New integration → Internal
# Then share your task-source page WITH the integration (page → Connections → Add).

NOTION_TOKEN="ntn_<paste-your-integration-token-here>"

# =============================================================================
# REQUIRED — Google Calendar / Gmail OAuth file paths
# =============================================================================
# Get these by creating a Desktop app OAuth client in Google Cloud Console,
# enabling Calendar + Gmail APIs, downloading credentials.json. First run will
# trigger a browser OAuth handshake and save token.json next to credentials.json.

GCAL_CREDENTIALS_PATH="/Users/<you>/.config/gcal-mcp/credentials.json"
GMAIL_CREDENTIALS_PATH="/Users/<you>/.config/gmail-mcp/credentials.json"
GMAIL_TOKEN_PATH="/Users/<you>/.config/gmail-mcp/token.json"

# =============================================================================
# OPTIONAL — sensible defaults
# =============================================================================

MODEL="claude-sonnet-4-6"                     # claude-opus-4-7 for complex weeks
TIMEZONE="America/New_York"                   # IANA tz
CRON_HOUR="22"                                # if you ever schedule the cron
DEFAULT_MODE="auto"                           # "auto" writes blocks; "draft" reports only
EXTRA_ADD_DIRS=""                             # space-sep absolute paths the planner can read

# =============================================================================
# OPTIONAL — Codex side (only used if you also run the Codex target)
# =============================================================================

CODEX_MODEL="gpt-5.5"
CODEX_REASONING="xhigh"
CODEX_CWD=""                                  # default: $OBSIDIAN_VAULT_ROOT
